<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Top Bar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/primary"
        android:elevation="4dp"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- 3D Viewport -->
        <FrameLayout
            android:id="@+id/viewport_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/viewport_background">
            
            <!-- GLSurfaceView will be added programmatically -->
            
        </FrameLayout>

        <!-- Tools on Side -->
        <ScrollView
            android:layout_width="200dp"
            android:layout_height="match_parent"
            android:background="@color/surface">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Undo/Redo Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">
                    
                    <Button
                        android:id="@+id/btn_undo"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="↶"
                        android:textSize="20sp"
                        android:enabled="false" />
                    
                    <Button
                        android:id="@+id/btn_redo"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:text="↷"
                        android:textSize="20sp"
                        android:enabled="false" />
                </LinearLayout>

                <!-- Tool Buttons -->
                <Button
                    android:id="@+id/btn_remove"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="4dp"
                    android:text="🗑️ Remove"
                    android:textSize="14sp"
                    android:tooltipText="Remove - Carve clay inward" />

                <Button
                    android:id="@+id/btn_add"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="4dp"
                    android:text="➕ Add"
                    android:textSize="14sp"
                    android:tooltipText="Add - Build clay outward" />

                <Button
                    android:id="@+id/btn_pull"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="4dp"
                    android:text="👆 Pull"
                    android:textSize="14sp"
                    android:tooltipText="Pull - Drag clay in direction" />

                <Button
                    android:id="@+id/btn_smooth"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="4dp"
                    android:text="〰️ Smooth"
                    android:textSize="14sp"
                    android:tooltipText="Smooth - Polish surfaces" />

                <Button
                    android:id="@+id/btn_flatten"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="4dp"
                    android:text="▬ Flatten"
                    android:textSize="14sp"
                    android:tooltipText="Flatten - Create flat surfaces" />

                <Button
                    android:id="@+id/btn_pinch"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="4dp"
                    android:text="🤏 Pinch"
                    android:textSize="14sp"
                    android:tooltipText="Pinch - Sharp details" />

                <Button
                    android:id="@+id/btn_inflate"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="4dp"
                    android:text="🎈 Inflate"
                    android:textSize="14sp"
                    android:tooltipText="Inflate - Uniform expansion" />

                <Button
                    android:id="@+id/btn_view"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="16dp"
                    android:text="👁️ View"
                    android:textSize="14sp"
                    android:tooltipText="View - Examine without editing" />

                <!-- Settings -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Size:"
                    android:textSize="12sp" />

                <SeekBar
                    android:id="@+id/slider_size"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="50" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Strength:"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp" />

                <SeekBar
                    android:id="@+id/slider_strength"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="50" />

                <Button
                    android:id="@+id/btn_symmetry"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    android:text="Symmetry: OFF"
                    android:textSize="12sp"
                    android:contentDescription="Toggle symmetry" />

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

</LinearLayout>
