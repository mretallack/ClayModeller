<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- Top Bar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        android:elevation="4dp"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar" />

    <!-- 3D Viewport -->
    <FrameLayout
        android:id="@+id/viewport_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/viewport_background">
        
        <!-- GLSurfaceView will be added programmatically -->
        
    </FrameLayout>

    <!-- Tool Bar -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@color/tool_bar"
        android:scrollbars="none">
        
        <LinearLayout
            android:id="@+id/tool_bar"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp">

            <Button
                android:id="@+id/btn_undo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/tool_button_background"
                android:text="↶"
                android:textSize="24sp"
                android:enabled="false"
                android:contentDescription="Undo" />

            <Button
                android:id="@+id/btn_redo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/tool_button_background"
                android:text="↷"
                android:textSize="24sp"
                android:enabled="false"
                android:contentDescription="Redo" />

            <Button
                android:id="@+id/btn_remove"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/tool_button_background"
                android:text="🗑️"
                android:textSize="20sp"
                android:tooltipText="Remove"
                android:contentDescription="Remove clay tool" />

            <Button
                android:id="@+id/btn_add"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/tool_button_background"
                android:text="➕"
                android:textSize="20sp"
                android:tooltipText="Add"
                android:contentDescription="Add clay tool" />

            <Button
                android:id="@+id/btn_pull"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/tool_button_background"
                android:text="👆"
                android:textSize="20sp"
                android:tooltipText="Pull"
                android:contentDescription="Pull clay tool" />

            <Button
                android:id="@+id/btn_smooth"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/tool_button_background"
                android:text="〰️"
                android:textSize="20sp"
                android:tooltipText="Smooth"
                android:contentDescription="Smooth tool" />

            <Button
                android:id="@+id/btn_flatten"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/tool_button_background"
                android:text="▬"
                android:textSize="20sp"
                android:tooltipText="Flatten"
                android:contentDescription="Flatten tool" />

            <Button
                android:id="@+id/btn_pinch"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/tool_button_background"
                android:text="🤏"
                android:textSize="20sp"
                android:tooltipText="Pinch"
                android:contentDescription="Pinch tool" />

            <Button
                android:id="@+id/btn_inflate"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/tool_button_background"
                android:text="🎈"
                android:textSize="20sp"
                android:tooltipText="Inflate"
                android:contentDescription="Inflate tool" />

            <Button
                android:id="@+id/btn_view"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/tool_button_background"
                android:text="👁️"
                android:textSize="20sp"
                android:tooltipText="View"
                android:contentDescription="View mode" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Settings Panel -->
    <LinearLayout
        android:id="@+id/settings_panel"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="@color/surface"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Size:"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_symmetry"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:paddingHorizontal="12dp"
                android:text="Symmetry: OFF"
                android:textSize="11sp"
                android:background="@drawable/tool_button_background"
                android:contentDescription="Toggle symmetry" />

        </LinearLayout>

        <SeekBar
            android:id="@+id/slider_size"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="50" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Strength:"
            android:textSize="12sp"
            android:layout_marginTop="8dp" />

        <SeekBar
            android:id="@+id/slider_strength"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="50" />

    </LinearLayout>

</LinearLayout>
