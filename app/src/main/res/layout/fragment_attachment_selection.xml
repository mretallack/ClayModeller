<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Saved Presets"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:scrollbars="none">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/preset_chips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            xmlns:app="http://schemas.android.com/apk/res-auto" />
    </HorizontalScrollView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Attachment Type"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/radio_attachment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RadioButton
            android:id="@+id/radio_none"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="⊘  None — Export model only"
            android:minHeight="48dp" />

        <RadioButton
            android:id="@+id/radio_base"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="▬  Base — Flat base for standing"
            android:minHeight="48dp" />

        <RadioButton
            android:id="@+id/radio_keyring"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="◎  Keyring Loop — Attach to keychain"
            android:minHeight="48dp" />

        <RadioButton
            android:id="@+id/radio_hook"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="⌗  Wall Hook — Mount on wall"
            android:minHeight="48dp" />
    </RadioGroup>

    <TextView
        android:id="@+id/txt_combination_warning"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/accent"
        android:textSize="12sp"
        android:layout_marginTop="8dp"
        android:visibility="gone" />
</LinearLayout>
